#!/bin/bash
set -euxo pipefail

export DISPLAY=:1
export HOME=/root
export XFCE_ALLOW_ROOT=1

# Instruqt provides VNC (port 5900) and noVNC (port 8080) automatically.
# We just need XFCE and IntelliJ running on display :1.

# Start XFCE if not already running
if ! pgrep -x xfce4-session >/dev/null 2>&1; then
    startxfce4 &
    sleep 5
fi

# Launch IntelliJ IDEA
IDEA_BIN=$(ls /opt/idea-IC-*/bin/idea.sh 2>/dev/null | head -1)
if [ -n "$IDEA_BIN" ]; then
    nohup "$IDEA_BIN" /workspace/task_tracker >/tmp/idea.log 2>&1 &
    echo "IntelliJ IDEA launched."
fi

echo "Track environment ready."
exit 0
