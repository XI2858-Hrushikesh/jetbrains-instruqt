#!/bin/bash

if [ ! -f /tmp/c1-s3 ]; then
    fail-message "Step 3 not complete. Use Search Everywhere (Shift Shift) and Structure view in the IDE, then run: touch /tmp/c1-s3"
    exit 1
fi

if [ ! -f /tmp/c1-s6 ]; then
    fail-message "Step 6 not complete. Run: cd /workspace/task_tracker && python3 tasks.py add \"Fix login bug\" && touch /tmp/c1-s6"
    exit 1
fi

if [ ! -f /workspace/task_tracker/.run_done ]; then
    fail-message "Step 7 not complete. Run: touch /workspace/task_tracker/.run_done && touch /tmp/c1-s7"
    exit 1
fi

if ! python3 /workspace/task_tracker/tasks.py list 2>/dev/null | grep -q "Fix login bug"; then
    fail-message "The task was not added correctly. Run: cd /workspace/task_tracker && python3 tasks.py add \"Fix login bug\""
    exit 1
fi
